---
export const prerender = false;
import { db } from "@color-corpus/db";

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/404');
}

const result = await db.execute({
  sql: `
    SELECT sc.*, s.name as source_name, s.slug as source_slug, n.display_form
    FROM source_colors sc
    JOIN sources s ON sc.source_id = s.id
    LEFT JOIN color_name_assignments cna ON sc.id = cna.source_color_id
    LEFT JOIN names n ON cna.name_id = n.id
    WHERE sc.id = ?
  `,
  args: [id]
});

if (result.rows.length === 0) {
  return Astro.redirect('/404');
}

const color = result.rows[0];
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{color.display_form || color.primary_name_raw} - Color Detail</title>
    <link rel="stylesheet" href="https://unpkg.com/neobrutalismcss@latest" />
    <style>
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        background-color: #f0f0f0;
        margin: 0;
        padding: 0;
      }
      .nb-header {
        background-color: #ffffff;
        border-bottom: 4px solid #000;
        padding: 2rem;
        text-align: center;
      }
      .container {
        max-width: 800px;
        margin: 2rem auto;
        padding: 2rem;
        background: #fff;
        border: 4px solid #000;
        box-shadow: 8px 8px 0px #000;
      }
      .color-swatch {
        height: 300px;
        border: 4px solid #000;
        margin-bottom: 2rem;
      }
      .meta-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
      }
      .meta-item {
        border: 2px solid #000;
        padding: 1rem;
      }
      .meta-label {
        font-weight: bold;
        text-transform: uppercase;
        font-size: 0.8rem;
        color: #666;
        margin-bottom: 0.5rem;
      }
      .meta-value {
        font-size: 1.2rem;
        font-weight: bold;
      }
    </style>
  </head>
  <body>
    <header class="nb-header">
      <h1>{color.display_form || color.primary_name_raw}</h1>
      <a href="/">← Back Home</a>
    </header>

    <main class="container">
      <div class="color-swatch" style={`background-color: ${color.hex_color};`}></div>
      
      <div class="meta-grid">
        <div class="meta-item">
          <div class="meta-label">Hex Code</div>
          <div class="meta-value">{color.hex_color}</div>
        </div>
        <div class="meta-item">
          <div class="meta-label">Source</div>
          <div class="meta-value">
            <a href={`/sources/${color.source_slug}`}>{color.source_name}</a>
          </div>
        </div>
        <div class="meta-item">
          <div class="meta-label">Raw Name</div>
          <div class="meta-value">{color.primary_name_raw}</div>
        </div>
        <div class="meta-item">
          <div class="meta-label">Color ID</div>
          <div class="meta-value" style="font-size: 0.9rem; word-break: break-all;">{color.id}</div>
        </div>
      </div>
    </main>
  </body>
</html>
