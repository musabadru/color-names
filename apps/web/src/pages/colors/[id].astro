---
export const prerender = false;
import { db } from "@color-corpus/db";
import Layout from '../../layouts/Layout.astro';

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/404');
}

const result = await db.execute({
  sql: `
    SELECT sc.*, s.name as source_name, s.slug as source_slug, n.display_form
    FROM source_colors sc
    JOIN sources s ON sc.source_id = s.id
    LEFT JOIN color_name_assignments cna ON sc.id = cna.source_color_id
    LEFT JOIN names n ON cna.name_id = n.id
    WHERE sc.id = ?
  `,
  args: [id]
});

if (result.rows.length === 0) {
  return Astro.redirect('/404');
}

const color = result.rows[0];
---

<Layout title={`${color.display_form || color.primary_name_raw} - Color Detail`}>
  <header class="nb-header">
    <h1 style="font-weight: 900;">{color.display_form || color.primary_name_raw}</h1>
    <a href="/" style="font-family: var(--font-mono); font-weight: bold; color: #000; text-decoration: none; border-bottom: 2px solid #000; padding-bottom: 2px;">← Back Home</a>
  </header>

  <main class="container">
    <div style="max-width: 800px; margin: 0 auto; background: #fff; border: var(--border-thick); box-shadow: var(--shadow-brutal); padding: 2rem;">
      <div style={`height: 300px; border: var(--border-thick); margin-bottom: 2rem; background-color: ${color.hex_color}; box-shadow: var(--shadow-brutal-active);`}></div>
      
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
        <div style="border: 2px solid #000; padding: 1rem; box-shadow: 2px 2px 0px #000;">
          <div style="font-family: var(--font-mono); font-weight: bold; text-transform: uppercase; font-size: 0.8rem; color: #000; margin-bottom: 0.5rem; background: #DDF247; display: inline-block; padding: 2px 6px; border: 1px solid #000;">Hex Code</div>
          <div style="font-family: var(--font-mono); font-size: 1.5rem; font-weight: 700;">{color.hex_color}</div>
        </div>
        <div style="border: 2px solid #000; padding: 1rem; box-shadow: 2px 2px 0px #000;">
          <div style="font-family: var(--font-mono); font-weight: bold; text-transform: uppercase; font-size: 0.8rem; color: #000; margin-bottom: 0.5rem; background: #DDF247; display: inline-block; padding: 2px 6px; border: 1px solid #000;">Source</div>
          <div style="font-family: var(--font-body); font-size: 1.2rem; font-weight: 900;">
            <a href={`/sources/${color.source_slug}`} style="color: #000; text-decoration: underline;">{color.source_name}</a>
          </div>
        </div>
        <div style="border: 2px solid #000; padding: 1rem; box-shadow: 2px 2px 0px #000;">
          <div style="font-family: var(--font-mono); font-weight: bold; text-transform: uppercase; font-size: 0.8rem; color: #000; margin-bottom: 0.5rem; background: #DDF247; display: inline-block; padding: 2px 6px; border: 1px solid #000;">Raw Name</div>
          <div style="font-family: var(--font-body); font-size: 1.2rem; font-weight: 900;">{color.primary_name_raw}</div>
        </div>
        <div style="border: 2px solid #000; padding: 1rem; box-shadow: 2px 2px 0px #000;">
          <div style="font-family: var(--font-mono); font-weight: bold; text-transform: uppercase; font-size: 0.8rem; color: #000; margin-bottom: 0.5rem; background: #DDF247; display: inline-block; padding: 2px 6px; border: 1px solid #000;">Color ID</div>
          <div style="font-family: var(--font-mono); font-size: 0.9rem; font-weight: 700; word-break: break-all;">{color.id}</div>
        </div>
      </div>
    </div>
  </main>
</Layout>
