---
export const prerender = false;
import { db } from "@color-corpus/db";
import Layout from '../../layouts/Layout.astro';

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/404');
}

const sourceResult = await db.execute({
  sql: `SELECT * FROM sources WHERE slug = ?`,
  args: [slug]
});

if (sourceResult.rows.length === 0) {
  return Astro.redirect('/404');
}

const source = sourceResult.rows[0];

const colorsResult = await db.execute({
  sql: `
    SELECT sc.id, sc.primary_name_raw as name, sc.hex_color as hex
    FROM source_colors sc
    WHERE sc.source_id = ?
  `,
  args: [source.id]
});

const colors = colorsResult.rows;
---
<Layout title={`${source.name} - Color Names`}>
  <header class="nb-header">
    <h1>{source.name}</h1>
    <p style="font-family: var(--font-mono); font-weight: 700; margin: 0 auto 1rem; background: #DDF247; display: inline-block; padding: 0.25rem 0.5rem; border: 2px solid #000;">{source.kind} • {source.language} • {colors.length} colors</p>
    <br>
    <a href="/sources" style="font-family: var(--font-mono); font-weight: bold; color: #000; text-decoration: none; border-bottom: 2px solid #000; padding-bottom: 2px;">← Back to Sources</a>
  </header>

  <main class="container">
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 3rem;">
      {colors.map((color) => (
        <a href={`/colors/${color.id}`} style="border: var(--border-thick); background-color: #fff; text-decoration: none; color: inherit; box-shadow: var(--shadow-brutal); transition: transform 0.1s ease-out, box-shadow 0.1s ease-out; display: flex; flex-direction: column;" onmouseover="this.style.transform='translate(-4px, -4px)'; this.style.boxShadow='var(--shadow-brutal-hover)';" onmouseout="this.style.transform='none'; this.style.boxShadow='var(--shadow-brutal)';">
          <div style={`height: 180px; border-bottom: var(--border-thick); background-color: ${color.hex}; transition: filter 0.2s;`} onmouseover="this.style.filter='brightness(1.05) contrast(1.1)'" onmouseout="this.style.filter='none'"></div>
          <div style="padding: 1.5rem 1.5rem 0.5rem; font-family: var(--font-heading); font-weight: 900; font-size: 1.5rem; line-height: 1.1; text-transform: uppercase; letter-spacing: -0.02em;">{color.name}</div>
          <div style="padding: 0 1.5rem 1.5rem; font-family: var(--font-mono); font-weight: 700; font-size: 1.2rem; margin-top: auto;">{color.hex}</div>
        </a>
      ))}
    </div>
  </main>
</Layout>
