---
import { db } from "@color-corpus/db";

const result = await db.execute(`SELECT * FROM sources`);
const sources = result.rows;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Sources - Color Names</title>
    <link rel="stylesheet" href="https://unpkg.com/neobrutalismcss@latest" />
    <style>
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        background-color: #f0f0f0;
        margin: 0;
        padding: 0;
      }
      .nb-header {
        background-color: #ffffff;
        border-bottom: 4px solid #000;
        padding: 2rem;
        text-align: center;
      }
      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem;
      }
      .source-card {
        border: 3px solid #000;
        background-color: #fff;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
        box-shadow: 5px 5px 0px #000;
        text-decoration: none;
        color: #000;
        display: block;
        transition: transform 0.1s, box-shadow 0.1s;
      }
      .source-card:hover {
        transform: translate(-2px, -2px);
        box-shadow: 7px 7px 0px #000;
      }
    </style>
  </head>
  <body>
    <header class="nb-header">
      <h1>Sources</h1>
      <a href="/">← Back Home</a>
    </header>

    <main class="container">
      {sources.map((source) => (
        <a href={`/sources/${source.slug}`} class="source-card">
          <h2>{source.name}</h2>
          <p>{source.kind} • {source.language}</p>
        </a>
      ))}
    </main>
  </body>
</html>
