---
import { db } from "@color-corpus/db";
import Layout from '../../layouts/Layout.astro';

const result = await db.execute(`SELECT * FROM sources`);
const sources = result.rows;
---
<Layout title="Sources - Color Names">
  <header class="nb-header">
    <h1>Sources</h1>
    <a href="/" style="font-family: var(--font-mono); font-weight: bold; color: #000; text-decoration: none; border-bottom: 2px solid #000; padding-bottom: 2px;">← Back Home</a>
  </header>

  <main class="container">
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 2rem;">
      {sources.map((source) => (
        <a href={`/sources/${source.slug}`} style="border: var(--border-thick); background-color: #fff; padding: 2rem; box-shadow: var(--shadow-brutal); text-decoration: none; color: #000; display: block; transition: transform 0.1s, box-shadow 0.1s;" onmouseover="this.style.transform='translate(-4px, -4px)'; this.style.boxShadow='var(--shadow-brutal-hover)';" onmouseout="this.style.transform='none'; this.style.boxShadow='var(--shadow-brutal)';">
          <h2 style="font-family: var(--font-heading); font-size: 2rem; font-weight: 900; margin: 0 0 1rem 0; text-transform: uppercase;">{source.name}</h2>
          <p style="font-family: var(--font-mono); font-weight: 700; margin: 0; background: #DDF247; display: inline-block; padding: 0.25rem 0.5rem; border: 2px solid #000;">{source.kind} • {source.language}</p>
        </a>
      ))}
    </div>
  </main>
</Layout>
