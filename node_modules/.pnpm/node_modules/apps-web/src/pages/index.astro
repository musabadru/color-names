---
import Search from '../components/Search.svelte';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Color Names</title>
    <!-- NeoBrutalism CSS -->
    <link rel="stylesheet" href="https://unpkg.com/neobrutalismcss@latest" />
    <style>
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        background-color: #f0f0f0;
        margin: 0;
        padding: 0;
      }
      .nb-header {
        background-color: #ffffff;
        border-bottom: 4px solid #000;
        padding: 2rem;
        text-align: center;
      }
      .nb-header h1 {
        font-size: 3rem;
        margin-bottom: 1rem;
        text-transform: uppercase;
      }
      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem;
      }
    </style>
  </head>
  <body>
    <header class="nb-header">
      <h1>Color Names</h1>
      <p>A curated collection of beautiful, vibrant colors for Neo-Brutalist designs. Click any card to copy the hex code.</p>
    </header>

    <main class="container">
      <Search client:load />
    </main>
  </body>
</html>
